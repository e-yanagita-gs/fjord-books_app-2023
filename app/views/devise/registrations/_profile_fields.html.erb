<div class="field">
  <%= f.label :name %><br />
  <%= f.text_field :name %>
</div>

<div class="field">
  <%= f.label :postal_code %><br />
  <%= f.text_field :postal_code %>
</div>

<div class="field">
  <%= f.label :address %><br />
  <%= f.text_field :address %>
</div>

<div class="field">
  <%= f.label :self_introduction %><br />
  <%= f.text_area :self_introduction %>
</div>

<div>
  <%= f.label :avatar, style: "display: block" %>
  <% if @user.avatar.attached? && @user.avatar.blob.image? %>
    <%= image_tag @user.avatar.variant(:small) %>
  <% elsif session[:original_avatar_url].present? %>
    <%= image_tag session[:original_avatar_url] %>
  <% end %>
  <%= f.file_field :avatar %>
</div>
