<p style="color: green"><%= notice %></p>
<h1><%= User.human_attribute_name(:profile) %></h1>

<div class="show-item">
  <%= render @user %>
</div>

<nav class="page-nav">
  <% if user_signed_in? && @user == current_user %>
    <%= link_to t('views.common.edit', name: User.model_name.human), edit_user_registration_path %> |
  <% end %>
  <%= link_to t('devise.shared.links.back'), :back %>
</nav>
